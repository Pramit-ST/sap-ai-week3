{
  "name": "sap-ai-week3",
  "version": "1.0.0",
  "description": "CAP Node.js service with LLM and Embeddings via Ollama",
  "main": "index.js",
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch"
  },
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9.8.0",
    "@sap/xssec": "^4.13.0",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "hana",
        "pool": {
          "acquireTimeoutMillis": 60000,
          "createTimeoutMillis": 30000,
          "destroyTimeoutMillis": 5000,
          "idleTimeoutMillis": 30000,
          "reapIntervalMillis": 1000,
          "min": 0,
          "max": 10
        },
        "auth": {
          "kind": "xsuaa"
        }
      }
    }
  }
}